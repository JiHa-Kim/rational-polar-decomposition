@article{nakatsukasaOptimizingHalleysIteration2010a,
  title = {Optimizing {{Halley}}'s {{Iteration}} for {{Computing}} the {{Matrix Polar Decomposition}}},
  author = {Nakatsukasa, Yuji and Bai, Zhaojun and Gygi, Fran{\c c}ois},
  year = 2010,
  month = jan,
  journal = {SIAM Journal on Matrix Analysis and Applications},
  volume = {31},
  number = {5},
  pages = {2700--2720},
  issn = {0895-4798, 1095-7162},
  doi = {10.1137/090774999},
  url = {http://epubs.siam.org/doi/10.1137/090774999},
  urldate = {2026-03-08},
  abstract = {We introduce a dynamically weighted Halley (DWH) iteration for computing the polar decomposition of a matrix, and prove that the new method is globally and asymptotically cubically convergent. For matrices with condition number no greater than 1016, the DWH method needs at most 6 iterations for convergence with the tolerance 10-16. The Halley iteration can be implemented via QR decompositions without explicit matrix inversion. Therefore, it is an inverse free and a communication friendly algorithm for the emerging multicore and hybrid high performance computing systems.},
  langid = {english}
}
